# Database URL (Supabase PostgreSQL Connection String)
# Example: postgresql://postgres:your-db-password@db.your-supabase-id.supabase.co:5432/postgres
DATABASE_URL=

# Supabase Storage Details
# Locate in your Supabase Dashboard Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key is required for admin file upload/delete operations bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=

# CORS Allowed Origins (Comma-separated URLs)
# Example: https://optiml-client.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Set to true to drop and recreate database tables on application start
# WARNING: Keep false in production to prevent data loss on server restarts.
RESET_DB_ON_STARTUP=false
